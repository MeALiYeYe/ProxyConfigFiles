name: Ultimate Sync_ruleconvert

on:
  workflow_dispatch:
  schedule:
    - cron: '0 0 * * *'

concurrency:
  group: rules-pipeline
  cancel-in-progress: true

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v5

      ################################
      # 1️⃣ Sync Rules (with hash check)
      ################################
      - name: Sync rules
        run: |
          set -e

          mkdir -p Surge/rule

          declare -A RULES=(
            ["FakeLocation"]="https://raw.githubusercontent.com/SunsetMkt/anti-ip-attribution/main/generated/surge.list"
          )

          changed=0

          for name in "${!RULES[@]}"; do
            url="${RULES[$name]}"
            target="Surge/rule/$name/$name.list"

            mkdir -p "$(dirname "$target")"

            tmp=$(mktemp)

            curl -L --fail --retry 3 "$url" -o "$tmp"

            if [ -f "$target" ] && cmp -s "$target" "$tmp"; then
              echo "No change: $name"
              rm -f "$tmp"
            else
              mv "$tmp" "$target"
              echo "Updated: $target"
              changed=1
            fi
          done

          echo "changed=$changed" >> $GITHUB_ENV

      ################################
      # 2️⃣ Generate Rules (Core Engine)
      ################################
      - name: Generate rules
        run: |
          set -e

          mkdir -p Mihomo/rule Egern/rule "Quantumult X/rule"

          extract() {
            grep "^$1," "$2" | cut -d',' -f2
          }

          collapse_ip() {
            python3 - "$1" "$2" << 'PY'
import sys, ipaddress
mode, file = sys.argv[1], sys.argv[2]
with open(file) as f:
    nets = [ipaddress.ip_network(line.strip(), strict=False) for line in f if line.strip()]
collapsed = sorted(ipaddress.collapse_addresses(nets))
for net in collapsed:
    if (mode=="ipv4" and net.version==4) or (mode=="ipv6" and net.version==6):
        print(net)
PY
          }

          total=0
          stats_json="{}"

          while read -r file; do

            name="${file#Surge/rule/}"
            name="${name%.list}"

            tmp=$(mktemp)

            sed '/^#/d;/^$/d' "$file" | sort -u > "$tmp"

            sorted=$(mktemp)

            grep '^DOMAIN' "$tmp" >> "$sorted" || true

            ipv4=$(mktemp)
            ipv6=$(mktemp)

            extract "IP-CIDR" "$tmp" > "$ipv4" || true
            extract "IP-CIDR6" "$tmp" > "$ipv6" || true

            if [ -s "$ipv4" ]; then
              collapse_ip ipv4 "$ipv4" | sed 's/^/IP-CIDR,/' >> "$sorted"
            fi

            if [ -s "$ipv6" ]; then
              collapse_ip ipv6 "$ipv6" | sed 's/^/IP-CIDR6,/' >> "$sorted"
            fi

            ################################
            # Mihomo
            ################################

            domain_out="Mihomo/rule/$name.yaml"
            ip_out="Mihomo/rule/${name}_ip.yaml"

            mkdir -p "$(dirname "$domain_out")"

            {
              echo "payload:"
              extract DOMAIN "$sorted" | sed 's/^/  - /'
              extract DOMAIN-SUFFIX "$sorted" | sed 's/^/  - +./'
            } > "$domain_out"

            {
              echo "payload:"
              extract IP-CIDR "$sorted"
              extract IP-CIDR6 "$sorted"
            } | sed 's/^/  - /' > "$ip_out"

            ################################
            # Egern（表驱动）
            ################################

            declare -A MAP=(
              ["DOMAIN-SUFFIX"]="domain_suffix_set"
              ["DOMAIN"]="domain_set"
              ["IP-CIDR"]="ip_cidr_set"
              ["IP-CIDR6"]="ip_cidr6_set"
            )

            egern="Egern/rule/$name.yaml"
            rm -f "$egern"

            for k in "${!MAP[@]}"; do
              if grep -q "^$k," "$sorted"; then
                echo "${MAP[$k]}:" >> "$egern"
                extract "$k" "$sorted" | sed 's/^/  - /' >> "$egern"
              fi
            done

            ################################
            # QX
            ################################
            cp "$sorted" "Quantumult X/rule/$name.list"

            ################################
            # Stats
            ################################
            count=$(wc -l < "$sorted")
            total=$((total + count))

            stats_json=$(python3 - <<EOF
import json
d=json.loads('''$stats_json''')
d["$name"]=$count
print(json.dumps(d))
EOF
)

          done < <(find Surge/rule -name '*.list')

          echo "$stats_json" > stats.json
          echo "total=$total" >> $GITHUB_ENV

      ################################
      # 3️⃣ Download Mihomo
      ################################
      - name: Download Mihomo
        run: |
          set -e
          curl -L -o mihomo.gz https://github.com/MetaCubeX/mihomo/releases/latest/download/mihomo-linux-amd64.gz
          gunzip -f mihomo.gz
          chmod +x mihomo

      ################################
      # 4️⃣ YAML → MRS
      ################################
      - name: Convert MRS
        run: |
          find Mihomo/rule -name '*.yaml' | while read -r f; do
            if grep -q '/' "$f"; then
              type=ipcidr
            else
              type=domain
            fi
            ./mihomo convert-ruleset $type yaml "$f" "${f%.yaml}.mrs"
          done

      ################################
      # 5️⃣ README + Badge
      ################################
      - name: Generate README
        run: |
          total=${{ env.total }}

          cat > README.md <<EOF
# Ruleset

![rules](https://img.shields.io/badge/rules-$total-blue)

## Stats
\`\`\`json
$(cat stats.json)
\`\`\`
EOF

      ################################
      # 6️⃣ Commit (smart)
      ################################
      - name: Commit
        run: |
          git config user.name github-actions
          git config user.email actions@github.com

          git add .

          if git diff --cached --quiet; then
            echo "No changes"
            exit 0
          fi

          git commit -m "auto: rules update (total=${{ env.total }})"

          git pull --rebase origin main
          git push
